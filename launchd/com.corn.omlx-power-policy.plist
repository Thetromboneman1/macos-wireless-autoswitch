<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.corn.omlx-power-policy</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/corn/.omlx/bin/omlx-power-watch.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/corn/.omlx/logs/power-policy.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/corn/.omlx/logs/power-policy.log</string>

    <key>ThrottleInterval</key>
    <integer>30</integer>
</dict>
</plist>
