# Odysseus Docker/Gemma setup
# Copy to odysseus/.env before first start, then edit only local values.

# Use upstream main for the stable curated branch. Set to a commit SHA or dev
# if you intentionally want the latest development branch.
ODYSSEUS_GIT_REF=main

# Loopback-only by default. Change APP_BIND only for a trusted LAN/VPN/reverse proxy.
APP_BIND=127.0.0.1
APP_PORT=7000
AUTH_ENABLED=true
LOCALHOST_BYPASS=false
ODYSSEUS_ADMIN_USER=admin
# ODYSSEUS_ADMIN_PASSWORD=

# Host user/group for bind-mounted files. On macOS, 501/20 is common.
PUID=501
PGID=20

# The Odysseus container reaches host model servers through host.docker.internal.
# Defaults assume all four Gemma models are exposed by one OpenAI-compatible
# server, such as Ollama/vLLM/llama.cpp/LM Studio on the host.
ODYSSEUS_GEMMA_BASE_URL=http://host.docker.internal:11434/v1

# Override per-role URLs only when the models are served on different ports/hosts.
# ODYSSEUS_GEMMA_PRIMARY_BASE_URL=http://host.docker.internal:8001/v1
# ODYSSEUS_GEMMA_CODING_BASE_URL=http://host.docker.internal:8002/v1
# ODYSSEUS_GEMMA_FAST_BASE_URL=http://host.docker.internal:8003/v1
# ODYSSEUS_GEMMA_SMALL_BASE_URL=http://host.docker.internal:8004/v1

ODYSSEUS_GEMMA_PRIMARY_MODEL=google/gemma-4-31B-it
ODYSSEUS_GEMMA_CODING_MODEL=google/gemma-4-26B-A4B-it
ODYSSEUS_GEMMA_FAST_MODEL=google/gemma-4-E4B-it
ODYSSEUS_GEMMA_SMALL_MODEL=google/gemma-4-E2B-it

# Optional embedding endpoint. Keep blank to use Odysseus' local fastembed fallback.
# EMBEDDING_URL=http://host.docker.internal:11434/v1/embeddings
# EMBEDDING_MODEL=google/embeddinggemma-300m

# Optional provider/download secrets. These are intentionally Odysseus-scoped
# names so Docker Compose does not inherit unrelated shell secrets by accident.
# ODYSSEUS_OPENAI_API_KEY=
# ODYSSEUS_HF_TOKEN=
